  <name>HonkHonk</name>
  <summary>Wayland-native Linux soundboard</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <description>
    <p>
      HonkHonk is a Wayland-native soundboard for Linux. Play sounds directly
      into your microphone via a PipeWire virtual mic — works with Discord,
      Mumble, and any PulseAudio-compatible application.
    </p>
  </description>

  <launchable type="desktop-id">io.github.thewrz.HonkHonk.desktop</launchable>

  <url type="homepage">https://github.com/thewrz/HonkHonk</url>
  <url type="bugtracker">https://github.com/thewrz/HonkHonk/issues</url>

  <categories>
    <category>Audio</category>
    <category>AudioVideo</category>
  </categories>

