# Maintainer: thewrz <adam@wrze.ski>
# GPG: B514 CBC5 B44C AACF 02EA  0D68 B461 236C F8EA 7961

pkgname=honkhonk-bin
pkgver=0.1.0
_pkgtag=0.1.0
pkgrel=1
pkgdesc="Wayland-native Linux soundboard — Iced GUI + PipeWire audio (binary release)"
arch=('x86_64')
url="https://github.com/wrzonance/HonkHonk"
license=('MIT')
# NOTE: as of 0.1.0 the released binary no longer links libxdo.so (tray-icon/
# muda built with default-features=false), so `xdotool` is not a dependency —
# this also ends the Debian libxdo.so.3 vs Arch libxdo.so.4 soname mismatch
# that blocked earlier versions of this package.
depends=(
    'pipewire'
    'wayland'
    'libxkbcommon'
    'gtk3'
    'libayatana-appindicator'
    'xdg-desktop-portal'
)
provides=('honkhonk')
conflicts=('honkhonk' 'honkhonk-git')
# The .deb is the released binary (SKIP — content varies per release). The
# conf.d drop-in is vendored locally next to this PKGBUILD so the AUR package
# always ships the current persistent-source config (issue #49) regardless of
# which .deb is attached to the release — an older .deb may not contain it yet.
# A test asserts this copy stays byte-identical to packaging/pipewire/50-honkhonk.conf.
source=(
    "$pkgname-$pkgver.deb::$url/releases/download/$_pkgtag/honkhonk_${pkgver}-1_amd64.deb"
    "50-honkhonk.conf"
)
sha256sums=(
    'SKIP'
    '4c3ce7ceffb122eb845c228026c340fbc689acd7139531975f4b06a0e74e6dcc'
)

prepare() {
    bsdtar -xf "$pkgname-$pkgver.deb" -C "$srcdir"
    bsdtar -xf "$srcdir"/data.tar* -C "$srcdir"
}

package() {
    install -Dm755 "$srcdir/usr/bin/honkhonk" "$pkgdir/usr/bin/honkhonk"
    install -Dm644 "$srcdir/usr/share/applications/honkhonk.desktop" \
        "$pkgdir/usr/share/applications/honkhonk.desktop"
    install -Dm644 "$srcdir/usr/share/icons/hicolor/256x256/apps/honkhonk.png" \
        "$pkgdir/usr/share/icons/hicolor/256x256/apps/honkhonk.png"
    # Persistent virtual-source PipeWire drop-in (issue #49). Installed from the
    # locally-vendored copy so "HonkHonk Mic" persists across reboots even when
    # the released .deb predates this drop-in.
    install -Dm644 "$srcdir/50-honkhonk.conf" \
        "$pkgdir/usr/share/pipewire/pipewire.conf.d/50-honkhonk.conf"
}
